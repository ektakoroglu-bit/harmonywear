# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Supabase — get from https://supabase.com/dashboard/project/<project-id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # server-side only, never expose to client

# Iyzico Payment (get from https://merchant.iyzipay.com)
# Leave empty to use DEMO mode (simulated payments)
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox.iyzipay.com

# Admin password (change in production!)
# Default demo password: forma2024

# Email — Nodemailer with Gmail SMTP
# 1. Enable 2-Step Verification on your Gmail account
# 2. Go to Google Account > Security > App Passwords
# 3. Create an App Password (select "Mail" + "Windows Computer")
# 4. Paste the 16-character password below (no spaces)
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-app-password-here

# Admin notification email (where to send new order alerts)
# Leave empty to use EMAIL_USER
ADMIN_EMAIL=your-admin@gmail.com
